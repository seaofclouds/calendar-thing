{
  "name": "@calendar-feeds/calendar",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "mkdir -p ../../dist && pnpm build:client && pnpm build:worker && pnpm build:assets",
    "build:client": "esbuild src/client.ts --bundle --outfile=../../dist/client.js --format=esm --target=es2020",
    "build:worker": "esbuild src/index.ts --bundle --outfile=../../dist/_worker.js --format=esm --target=es2020",
    "build:assets": "cp public/styles.css ../../dist/",
    "dev": "esbuild src/client.ts --bundle --outfile=public/client.js --format=esm --target=es2020 && wrangler dev",
    "deploy": "pnpm build && wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@calendar-feeds/feed-types": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "esbuild": "^0.24.0",
    "html-to-image": "^1.11.11",
    "typescript": "^5.7.2",
    "wrangler": "^3.93.0"
  }
}
