{
  "name": "@calendar-feeds/calendar",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "cp ../../packages/styles/base.css public/base.css && esbuild src/client.ts --bundle --outfile=public/client.js --format=esm --target=es2020",
    "build:client": "pnpm build",
    "dev": "pnpm build && wrangler dev",
    "deploy": "pnpm build && wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@calendar-feeds/feeds": "workspace:*",
    "@calendar-feeds/shared": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "esbuild": "^0.24.0",
    "html-to-image": "^1.11.11",
    "typescript": "^5.7.2",
    "wrangler": "^4.81.0"
  }
}
