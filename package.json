{
  "name": "calendar-feeds",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @calendar-feeds/calendar build",
    "typecheck": "pnpm -r run typecheck",
    "dev:astronomy": "pnpm --filter @calendar-feeds/astronomy dev",
    "dev:movie": "pnpm --filter @calendar-feeds/movie-release dev",
    "dev:astrology": "pnpm --filter @calendar-feeds/astrology dev",
    "dev:calendar": "pnpm --filter @calendar-feeds/calendar dev",
    "deploy:astrology": "pnpm --filter @calendar-feeds/astrology deploy",
    "deploy:astronomy": "pnpm --filter @calendar-feeds/astronomy deploy",
    "deploy:movie": "pnpm --filter @calendar-feeds/movie-release deploy",
    "deploy:calendar": "pnpm --filter @calendar-feeds/calendar deploy"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  }
}